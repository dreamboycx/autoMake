{
    "name": "dreamboycx/auto-make",
    "description": "base thinkphp6 auto create files",
    "type": "think-extend",
    "require": {
        "topthink/framework": "^6.0",
        "php": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "dreamboycx\\AutoMake\\": "src/"
        }
    },
    "extra": {
        "think": {
            "services": [
                "dreamboycx\\AutoMakeService"
            ],
            "config": {
                "myext": "config/autoMake.php"
            }
        }
    }
}
